import React from "react";
import "./Home.css";

const categories = [
	{ title: "Cardiovascular", count: 1, icon: "❤" },
	{ title: "Diabetes", count: 1, icon: "💧" },
	{ title: "Pain Relief", count: 2, icon: "⚡" },
	{ title: "Antibiotics", count: 1, icon: "💊" },
	{ title: "Dermatology", count: 1, icon: "✨" },
	{ title: "Digestive", count: 1, icon: "🔵" },
	{ title: "Vitamins", count: 1, icon: "☀️" },
	{ title: "Respiratory", count: 2, icon: "🌬️" },
];

export default function Home() {
	return (
		<div className="home-container">
			<section className="hero">
				<div className="hero-inner">
					<span className="badge">المنصة الصحية الرائدة</span>
					<h1 className="hero-title">صحتك، <span className="accent">مترابطة</span></h1>
					<p className="hero-sub">منصة متكاملة تربط المرضى والصيدليات والمستودعات وشركات الأدوية في نظام بيئي صحي موحد.</p>

					<div className="search-wrapper">
						<button className="search-button">بحث</button>
						<input className="search-input" placeholder="ابحث عن دواء أو مادة فعالة..." />
					</div>

					<div className="hero-cta">
						<button className="btn primary">ابدأ الآن</button>
						<button className="btn outline">تصفح الأدوية</button>
					</div>

					<div className="stats">
						<div className="stat">
							<div className="stat-num">+10K</div>
							<div className="stat-label">دواء</div>
						</div>
						<div className="stat">
							<div className="stat-num">+1,200</div>
							<div className="stat-label">صيدلية</div>
						</div>
						<div className="stat">
							<div className="stat-num">+50K</div>
							<div className="stat-label">مريض</div>
						</div>
					</div>
				</div>
			</section>

			<section className="categories">
				<h2 className="categories-title">تصفح حسب الفئة</h2>
				<div className="cards-grid">
					{categories.map((c, i) => (
						<div className="card" key={i}>
							<div className="card-icon" aria-hidden>
								<span className="icon-circle">{c.icon}</span>
							</div>
							<div className="card-body">
								<div className="card-title">{c.title}</div>
								<div className="card-sub">دواء {c.count}</div>
							</div>
						</div>
					))}
				</div>
			</section>
		</div>
	);
