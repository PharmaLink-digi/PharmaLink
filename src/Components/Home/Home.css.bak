:root{
	--bg-1: #f6fbfb;
	--accent-1: #0077ff;
	--accent-2: #00c2a8;
	--dark: #0b2540;
	--muted: #7b8b98;
}

.home-container{direction:rtl;font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;color:var(--dark);}

.hero{padding:80px 20px 120px;background:linear-gradient(180deg, #fbfdff 0%, #ffffff 50%);display:flex;justify-content:flex-end}
.hero-inner{max-width:980px;text-align:right;padding-right:80px}
.badge{display:inline-block;background:rgba(0,123,255,0.08);color:var(--accent-1);padding:8px 14px;border-radius:18px;font-size:13px;margin-bottom:18px}
.hero-title{font-size:48px;margin:8px 0 12px;font-weight:800}
.hero-title .accent{background:linear-gradient(90deg,var(--accent-1),var(--accent-2));-webkit-background-clip:text;background-clip:text;color:transparent}
.hero-sub{color:var(--muted);max-width:760px;margin:0 auto 28px}

.search-wrapper{display:flex;flex-direction:row-reverse;align-items:center;gap:10px;margin:28px 0 22px;max-width:680px;background:#fff;border-radius:30px;padding:6px 6px;box-shadow:0 6px 20px rgba(15,40,70,0.06);justify-content:flex-end}
.search-input{flex:1;border:0;padding:16px 20px;border-radius:28px;font-size:16px;outline:none;color:var(--dark)}
.search-input::placeholder{color:#b8c4cc}
.search-button{background:linear-gradient(90deg,var(--accent-1),var(--accent-2));color:#fff;border:0;padding:12px 22px;border-radius:28px;font-weight:600;cursor:pointer}

.hero-cta{display:flex;flex-direction:row-reverse;gap:12px;justify-content:flex-end;margin-top:16px}
.btn{padding:10px 18px;border-radius:22px;border:0;cursor:pointer;font-weight:600}
.btn.primary{background:linear-gradient(90deg,var(--accent-1),var(--accent-2));color:#fff}
.btn.outline{background:#fff;border:1px solid rgba(11,37,64,0.06);color:var(--dark)}

.stats{display:flex;flex-direction:row-reverse;gap:36px;justify-content:flex-end;margin-top:34px}
.stat{text-align:center}
.stat-num{font-weight:800;color:var(--accent-1);font-size:20px}
.stat-label{color:var(--muted);font-size:13px}

.categories{max-width:1200px;margin:40px auto;padding:20px}
.categories-title{font-size:28px;text-align:right;margin:20px 0 18px;padding-right:40px}
.cards-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;direction:rtl}

.card{background:#fff;border-radius:14px;padding:38px 22px 38px 22px;padding-right:64px;position:relative;border:1px solid rgba(11,37,64,0.06);display:flex;flex-direction:row-reverse;align-items:center;justify-content:flex-end;transition:transform .28s cubic-bezier(.2,.9,.2,1),box-shadow .28s}
.card-body{margin:0 18px 0 0;text-align:right}
.card-title{font-weight:700;color:var(--dark)}
.card-sub{font-size:12px;color:var(--muted);margin-top:6px}

.card-icon{position:absolute;top:16px;right:16px}
.icon-circle{display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:50%;background:linear-gradient(180deg, rgba(0,123,255,0.12), rgba(0,194,168,0.12));color:var(--accent-1);font-size:18px;box-shadow:0 6px 18px rgba(0,123,255,0.06);transition:transform .28s,box-shadow .28s}

.card:hover{transform:translateY(-8px);box-shadow:0 12px 30px rgba(11,37,64,0.08)}
.card:hover .icon-circle{transform:scale(1.12);box-shadow:0 16px 36px rgba(0,123,255,0.12)}

@media (max-width:1000px){.cards-grid{grid-template-columns:repeat(2,1fr)}.hero-title{font-size:36px}}
@media (max-width:600px){.cards-grid{grid-template-columns:1fr}.search-wrapper{max-width:100%;padding:4px}.hero-inner{padding:0 14px}.hero{padding:40px 10px}}
